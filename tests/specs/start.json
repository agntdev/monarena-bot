[
  {
    "name": "/start onboarding flow: pick starter and enter name",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "👋 Welcome, new Trainer! First, pick your starter Pokémon:"
            }
          }
        ]
      },
      {
        "send": { "callback": "starter:charmander" },
        "expect": [
          {
            "method": "answerCallbackQuery"
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "Great choice! Charmander will be your partner.\n\nNow, what's your trainer name?"
            }
          }
        ]
      },
      {
        "send": { "text": "Ash" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🎉 Welcome, Ash!\n\nCharmander is now in your party. Here's what you got:\n• potion\n• potion\n• pokeball\n• pokeball\n• pokeball\n\nTap a button below to begin your adventure!"
            }
          }
        ]
      }
    ]
  },
  {
